# ============================================================
# ESG Platform Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.
#
# Quick setup: run ./scripts/setup-env.sh to generate .env
# ============================================================

# ── Database ──
POSTGRES_DB=esg_platform
POSTGRES_USER=esg_admin
DB_PASSWORD=                          # REQUIRED: Set a strong password (e.g. openssl rand -base64 32)

# ── Backend ──
JWT_SECRET=                           # REQUIRED: Set a 64+ char random string (e.g. openssl rand -base64 48)
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# ── Seed Admin Account ──
ADMIN_EMAIL=admin@esgl.local           # Change to your admin email
ADMIN_PASSWORD=   Admin@12345                    # REQUIRED: Set a strong admin password
ADMIN_NAME=System Administrator

# ── Computed (auto-generated by setup script) ──
# DATABASE_URL=postgresql://${POSTGRES_USER}:${DB_PASSWORD}@db:5432/${POSTGRES_DB}
